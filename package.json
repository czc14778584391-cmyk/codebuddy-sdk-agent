{
  "name": "codebuddy-agent-app",
  "version": "1.0.0",
  "description": "CodeBuddy Agent Web App - IDE-like AI Chat Interface",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:electron": "concurrently \"npm run dev:server\" \"npm run dev:web\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "build": "vite build",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tencent-ai/agent-sdk": "latest",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "sass": "^1.77.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.codebuddy.agent-app",
    "productName": "CodeBuddy Agent",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      ".env",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server/",
        "to": "server/"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
